[configuration]

entry_symbol = "godot_library_init"
compatibility_minimum = "4.5"
reloadable = true

[libraries]
windows.x86_64.single.debug = "./windows/godot_llama_cpp.windows.template_debug.x86_64.dll"
windows.x86_64.single.release = "./windows/godot_llama_cpp.windows.template_release.x86_64.dll"
